---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import { loadBooking } from '../lib/content';

const booking = await loadBooking();
const embed = Astro.url.searchParams.get('embed') === '1';
---
<BaseLayout title="Book - Oscar Sanchez" description="Book calls and workshops with explicit consent">
  <div class="book-shell">
    <section class="book-hero">
      <p class="book-eyebrow">Booking flow</p>
      <h1>Book</h1>
      <p>Paid teaching events and paid consulting. Pick a path, then book a slot below.</p>
      <p class="text-small">TL;DR: Teaching → workshops/classes. Consulting → 1:1 guidance. Choose the option that fits your next step.</p>
    </section>

    <section class="book-section book-paths">
      <div class="book-section-head">
        <h2>Paths</h2>
        <p class="book-section-note">Choose your lane</p>
      </div>
      <CardGrid gap="var(--space-3)" align="stretch">
        <div class="book-path-card book-path-card--teach">
          <Card>
            <h3>Paid teaching</h3>
            <p class="text-small">Workshops and classes for teams, schools, and communities.</p>
            <ul>
              <li>Formats: private workshop, guest lecture, hands-on build.</li>
              <li>You get: agenda, slides/labs, and a reusable scaffold.</li>
              <li>Best when: you want a shared baseline and a shipped demo.</li>
            </ul>
          </Card>
        </div>
        <div class="book-path-card book-path-card--consult">
          <Card>
            <h3>Paid consulting</h3>
            <p class="text-small">Short sessions to de-risk a build or a pilot.</p>
            <ul>
              <li>Format: 1:1 guidance or a team consult.</li>
              <li>You get: scoped next steps, risks, and a simple plan.</li>
              <li>Best when: you need a clear decision, not a long engagement.</li>
            </ul>
          </Card>
        </div>
      </CardGrid>
    </section>

    <section class="book-section book-open">
      <div class="book-section-head">
        <h2>Open by default</h2>
        <p class="book-section-note">Free artifacts stay public</p>
      </div>
      <div class="book-open-scope">
        <Card>
          <p>Paid work funds the free OSAN artifacts: workshops, modules, labs, and docs.</p>
          <p class="text-small book-open-links">
            If you want the free path first, start here:
            <a href="/workshops">Workshops</a>,
            <a href="/visual-classes">Modules</a>,
            <a href="/labs">Labs</a>,
            <a href="/join">Contribute</a>,
            or <a href="/resume">About</a>.
          </p>
        </Card>
      </div>
    </section>

    <section class="book-section book-booking">
      <div class="book-section-head">
        <h2>Book a slot</h2>
        <p class="book-section-note">Choose one and lock it in</p>
      </div>
      <p class="text-small">Calendly opens in a new tab. Use the Back link if you want to exit.</p>
      <div class="book-actions-grid">
        <CardGrid gap="var(--space-3)" align="stretch">
          <div class="book-action book-action--coaching">
            <Card>
              <h3>1:1 guidance</h3>
              {booking.calendly.one_on_one.url ? (
                <>
                  <a class="button" href={booking.calendly.one_on_one.url} target="_blank" rel="noopener noreferrer">{booking.calendly.one_on_one.label}</a>
                  {embed ? <iframe style="width:100%; margin-top:1rem; min-height:560px; border:1px solid var(--border);" src={booking.calendly.one_on_one.url} title="Calendly 1:1" loading="lazy"></iframe> : null}
                </>
              ) : (
                <p class="text-small">Add your Calendly URL in booking.json</p>
              )}
            </Card>
          </div>
          <div class="book-action book-action--workshop">
            <Card>
              <h3>Private workshop</h3>
              {booking.calendly.teach_private.url ? (
                <a class="button" href={booking.calendly.teach_private.url} target="_blank" rel="noopener noreferrer">{booking.calendly.teach_private.label}</a>
              ) : (
                <p class="text-small">Add your Calendly URL in booking.json</p>
              )}
            </Card>
          </div>
          <div class="book-action book-action--class">
            <Card>
              <h3>Class or school booking</h3>
              {booking.calendly.teach_class.url ? (
                <a class="button" href={booking.calendly.teach_class.url} target="_blank" rel="noopener noreferrer">{booking.calendly.teach_class.label}</a>
              ) : (
                <p class="text-small">Add your Calendly URL in booking.json</p>
              )}
            </Card>
          </div>
        </CardGrid>
      </div>
      <p class="muted">AI‑assisted; reviewed by humans; results vary.</p>
    </section>
  </div>
</BaseLayout>

<style>
  .book-shell {
    --book-accent: color-mix(in srgb, var(--scene-accent, var(--accent)) 62%, var(--ink) 8%);
    display: grid;
    gap: clamp(1.2rem, 2.2vw, 2rem);
    max-width: min(1020px, calc(100vw - 2rem));
    margin: 0 auto;
  }

  .book-hero {
    display: grid;
    gap: 0.58rem;
    border: 1px solid color-mix(in srgb, var(--scene-accent, var(--accent)) 16%, var(--stroke));
    border-radius: calc(var(--radius-lg) + 0.2rem);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--scene-accent-soft, color-mix(in srgb, var(--scene-accent, var(--accent)) 18%, transparent)) 38%, var(--panel)),
      var(--panel)
    );
    box-shadow: 0 14px 32px color-mix(in srgb, var(--ink) 6%, transparent);
    padding: clamp(1.05rem, 2vw, 1.45rem);
  }

  .book-eyebrow {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    margin: 0;
    border: 1px solid color-mix(in srgb, var(--scene-accent, var(--accent)) 28%, var(--stroke));
    border-radius: var(--radius-pill);
    padding: 0.22rem 0.62rem;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--ink) 86%, var(--scene-accent, var(--accent)));
    background: color-mix(in srgb, var(--surface) 90%, var(--scene-accent-soft));
  }

  .book-hero h1 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 2.85rem);
    line-height: 0.98;
  }

  .book-hero p {
    margin: 0;
    max-width: 66ch;
  }

  .book-section {
    display: grid;
    gap: 0.85rem;
  }

  .book-section-head {
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
    align-items: center;
  }

  .book-section-head h2 {
    margin: 0;
    letter-spacing: -0.01em;
    font-size: clamp(1.18rem, 2.4vw, 1.38rem);
    color: color-mix(in srgb, var(--ink) 94%, var(--scene-accent, var(--accent)));
  }

  .book-section-note {
    margin: 0;
    font-size: 0.78rem;
    color: var(--ink-subtle);
    border: 1px solid color-mix(in srgb, var(--scene-accent, var(--accent)) 20%, var(--stroke));
    border-radius: var(--radius-pill);
    padding: 0.18rem 0.58rem;
    background: color-mix(in srgb, var(--surface) 90%, var(--scene-accent-soft));
  }

  .book-paths {
    gap: 1rem;
  }

  .book-path-card {
    min-height: 100%;
    --path-accent: color-mix(in srgb, var(--scene-accent, var(--accent)) 42%, var(--stroke));
  }

  .book-path-card--teach {
    --path-accent: color-mix(in srgb, var(--cog-blue) 58%, var(--stroke));
  }

  .book-path-card--consult {
    --path-accent: color-mix(in srgb, var(--cog-mint) 56%, var(--stroke));
  }

  .book-path-card :global(.card) {
    position: relative;
    display: grid;
    gap: 0.62rem;
    min-height: 100%;
    padding: clamp(0.95rem, 1.8vw, 1.24rem);
    border-color: color-mix(in srgb, var(--path-accent) 56%, var(--stroke));
    background: color-mix(in srgb, var(--panel) 92%, var(--scene-accent-soft));
    box-shadow: 0 9px 22px color-mix(in srgb, var(--ink) 4%, transparent);
    overflow: hidden;
  }

  .book-path-card :global(.card)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0.2rem;
    background: var(--path-accent);
    border-radius: 999px;
    opacity: 0.85;
  }

  .book-path-card h3 {
    margin: 0;
    font-size: 1.45rem;
    line-height: 1.08;
  }

  .book-open {
    gap: 0.9rem;
  }

  .book-path-card ul {
    display: grid;
    gap: 0.48rem;
    margin: 0;
    padding-left: 1.2rem;
    color: color-mix(in srgb, var(--ink) 94%, var(--ink-soft));
  }

  .book-path-card li::marker {
    color: var(--path-accent);
  }

  .book-open-scope {
    min-height: 100%;
  }

  .book-open-scope :global(.card) {
    display: grid;
    gap: 0.45rem;
    padding: clamp(0.95rem, 1.8vw, 1.2rem);
    border-color: color-mix(in srgb, var(--scene-accent, var(--accent)) 24%, var(--stroke));
    background: color-mix(in srgb, var(--panel) 88%, var(--scene-accent-soft));
  }

  .book-open-scope p {
    max-width: 72ch;
    margin: 0;
  }

  .book-open-links a {
    color: color-mix(in srgb, var(--ink) 88%, var(--scene-accent, var(--accent)));
    font-weight: 600;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.15em;
  }

  .book-open-links a:hover,
  .book-open-links a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .book-booking {
    gap: 0.95rem;
  }

  .book-booking .text-small {
    margin: 0;
    color: var(--ink-subtle);
  }

  .book-action {
    min-height: 100%;
    --action-accent: color-mix(in srgb, var(--scene-accent, var(--accent)) 34%, var(--stroke));
  }

  .book-action--coaching {
    --action-accent: color-mix(in srgb, var(--cog-blue) 56%, var(--stroke));
  }

  .book-action--workshop {
    --action-accent: color-mix(in srgb, var(--cog-yellow) 54%, var(--stroke));
  }

  .book-action--class {
    --action-accent: color-mix(in srgb, var(--cog-mint) 56%, var(--stroke));
  }

  .book-action :global(.card) {
    display: grid;
    gap: 0.74rem;
    min-height: 100%;
    padding: clamp(0.9rem, 1.7vw, 1.15rem);
    border-color: color-mix(in srgb, var(--action-accent) 50%, var(--stroke));
    background: color-mix(in srgb, var(--panel) 92%, var(--white));
    box-shadow: 0 8px 20px color-mix(in srgb, var(--ink) 4%, transparent);
  }

  .book-action :global(h3) {
    margin: 0;
    font-size: clamp(1.22rem, 2.8vw, 1.42rem);
    line-height: 1.1;
  }

  .book-action :global(.button) {
    justify-self: start;
    min-width: 13.2rem;
    border-color: color-mix(in srgb, var(--action-accent) 72%, var(--ink));
    background: color-mix(in srgb, var(--surface) 88%, var(--scene-accent-soft));
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 0.68rem 1.05rem;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .book-action :global(.button)::after {
    content: '>';
    transform: translateX(0);
    transition: transform 180ms ease;
  }

  .book-action :global(.button:hover),
  .book-action :global(.button:focus-visible) {
    border-color: color-mix(in srgb, var(--action-accent) 90%, var(--ink));
    background: color-mix(in srgb, var(--surface) 72%, var(--scene-accent-soft));
  }

  .book-action :global(.button:hover)::after,
  .book-action :global(.button:focus-visible)::after {
    transform: translateX(2px);
  }

  .book-booking .muted {
    margin-top: 0.25rem;
    color: var(--ink-faint);
    font-size: 0.92rem;
  }

  @media (max-width: 720px) {
    .book-shell {
      gap: var(--space-3);
    }

    .book-hero {
      padding: 1rem;
    }

    .book-section-head {
      gap: 0.5rem;
    }

    .book-action :global(.card) {
      min-height: auto;
    }

    .book-action :global(.button) {
      width: 100%;
      justify-self: stretch;
      min-width: 0;
    }
  }
</style>
