---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import { loadBooking } from '../lib/content';

const booking = await loadBooking();
const embed = Astro.url.searchParams.get('embed') === '1';
---
<BaseLayout title="Book - Oscar Sanchez" description="Book calls and workshops with explicit consent">
  <div class="book-shell">
    <section class="book-hero">
      <div class="book-hero-main">
        <h1>Book</h1>
        <p>Paid teaching, consulting, and scoped builds. Pick a lane, then book below.</p>
        <p class="text-small">
          TL;DR: Teaching = workshops and talks. Consulting = advisory for orgs or individuals. Build = proposal-first delivery with acceptance checks.
        </p>
      </div>
      <aside class="book-hero-steps" aria-label="How this works">
        <p class="book-hero-steps__title">How this works</p>
        <ol>
          <li><strong>Choose path</strong><span>Teaching, consulting, or build.</span></li>
          <li><strong>Pick slot</strong><span>Use Calendly to lock a session.</span></li>
          <li><strong>Get outcome</strong><span>Leave with clear scoped next steps.</span></li>
        </ol>
      </aside>
    </section>

    <section class="book-section book-paths">
      <CardGrid gap="var(--space-3)" align="stretch">
        <div class="book-path-card book-path-card--teach">
          <Card>
            <h2>Teaching + speaking</h2>
            <p class="text-small">Workshops, classes, and talks on practical GenAI.</p>
            <ul class="text-small">
              <li>Formats: keynote, guest lecture, private workshop.</li>
              <li>You get: agenda, slides/labs, and a reusable scaffold.</li>
              <li>Best when: you need a shared baseline fast.</li>
            </ul>
          </Card>
        </div>
        <div class="book-path-card book-path-card--consult">
          <Card>
            <h2>Consulting</h2>
            <p class="text-small">Advisory for organizations and individuals. Clear scope. Clear next steps.</p>
            <ul class="text-small">
              <li>Orgs: GenAI integration, tool selection, evals, governance, AI marketing workflows.</li>
              <li>Individuals: workflows, content engines, portfolio, ship faster with AI.</li>
              <li>You get: next steps, risks, and a simple plan you can execute.</li>
            </ul>
          </Card>
        </div>
        <div class="book-path-card book-path-card--build">
          <Card>
            <h2>Build engagements</h2>
            <p class="text-small">If you want delivery, not just advice.</p>
            <ul class="text-small">
              <li>Start: scope lock workshop (inputs, owner, acceptance checks).</li>
              <li>Two paths: small pilot vs deeper build.</li>
              <li>Controls: approvals, audit logs, humans-in-the-loop.</li>
              <li>Handoff: runbook + docs + artifacts you keep.</li>
            </ul>
          </Card>
        </div>
      </CardGrid>
    </section>

    <section class="book-section book-open">
      <h2>Open by default</h2>
      <div class="book-open-scope">
        <Card>
          <p>Paid work funds the free OSAN artifacts: workshops, modules, labs, and docs.</p>
          <p class="text-small">When it makes sense, outcomes become reusable templates and scaffolds. I never publish client data or private context.</p>
          <p class="text-small book-open-links">
            If you want the free path first, start here:
            <a href="/workshops">Workshops</a>,
            <a href="/visual-classes">Modules</a>,
            <a href="/labs">Labs</a>,
            <a href="/join">Contribute</a>,
            or <a href="/resume">About</a>.
          </p>
        </Card>
      </div>
    </section>

    <section class="book-section book-booking">
      <h2>Book a slot</h2>
      <p class="text-small">Use 1:1 for individuals. Use Private workshop for teams, org consulting, or a scope lock. Use Class for teaching/speaking.</p>
      <p class="text-small">Calendly opens in a new tab. Use the Back link if you want to exit.</p>
      <div class="book-actions-grid">
        <CardGrid gap="var(--space-3)" align="stretch">
          <div class="book-action book-action--coaching">
            <Card>
              <h2>1:1 consulting (individuals)</h2>
              <p class="text-small">Best for personal workflows, content engines, and shipping faster with AI.</p>
              {booking.calendly.one_on_one.url ? (
                <>
                  <a class="button book-cta" href={booking.calendly.one_on_one.url} target="_blank" rel="noopener noreferrer">{booking.calendly.one_on_one.label}</a>
                  {embed ? <iframe style="width:100%; margin-top:1rem; min-height:560px; border:1px solid var(--border);" src={booking.calendly.one_on_one.url} title="Calendly 1:1" loading="lazy"></iframe> : null}
                </>
              ) : (
                <p class="text-small">Add your Calendly URL in booking.json</p>
              )}
            </Card>
          </div>
          <div class="book-action book-action--workshop">
            <Card>
              <h2>Org consulting or scope lock (teams)</h2>
              <p class="text-small">Best for GenAI integration planning, tooling decisions, or a build kickoff.</p>
              {booking.calendly.teach_private.url ? (
                <a class="button book-cta" href={booking.calendly.teach_private.url} target="_blank" rel="noopener noreferrer">{booking.calendly.teach_private.label}</a>
              ) : (
                <p class="text-small">Add your Calendly URL in booking.json</p>
              )}
            </Card>
          </div>
          <div class="book-action book-action--class">
            <Card>
              <h2>Teaching or speaking</h2>
              <p class="text-small">Best for talks, classes, and workshops.</p>
              {booking.calendly.teach_class.url ? (
                <a class="button book-cta" href={booking.calendly.teach_class.url} target="_blank" rel="noopener noreferrer">{booking.calendly.teach_class.label}</a>
              ) : (
                <p class="text-small">Add your Calendly URL in booking.json</p>
              )}
            </Card>
          </div>
        </CardGrid>
      </div>
      <p class="muted">AI‑assisted; reviewed by humans; results vary.</p>
    </section>
  </div>
</BaseLayout>

<style>
  .book-shell {
    --book-accent: var(--scene-accent, var(--accent));
    display: grid;
    gap: clamp(1.2rem, 2.1vw, 2rem);
    max-width: min(1040px, calc(100vw - 2rem));
    margin: 0 auto;
  }

  .book-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.92fr);
    gap: clamp(0.88rem, 2vw, 1.36rem);
    border: 1px solid color-mix(in srgb, var(--book-accent) 20%, var(--stroke));
    border-radius: calc(var(--radius-lg) + 0.2rem);
    background: color-mix(in srgb, var(--panel) 94%, var(--book-accent) 6%);
    box-shadow: 0 9px 21px color-mix(in srgb, var(--ink) 5%, transparent);
    padding: clamp(1rem, 1.9vw, 1.45rem);
  }

  .book-hero-main {
    display: grid;
    gap: 0.62rem;
    align-content: start;
  }

  .book-hero-main h1 {
    margin: 0;
    font-size: clamp(2rem, 4.8vw, 2.8rem);
    line-height: 0.98;
  }

  .book-hero-main p {
    margin: 0;
    max-width: 62ch;
    color: var(--ink-soft);
  }

  .book-hero-steps {
    display: grid;
    gap: 0.58rem;
    align-content: start;
    border: 1px solid color-mix(in srgb, var(--book-accent) 26%, var(--stroke));
    border-radius: calc(var(--radius-lg) - 0.08rem);
    background: color-mix(in srgb, var(--surface) 92%, var(--book-accent) 8%);
    padding: 0.9rem 0.95rem;
  }

  .book-hero-steps__title {
    margin: 0;
    font-size: 0.77rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink-subtle);
  }

  .book-hero-steps ol {
    list-style: none;
    counter-reset: book-step;
    display: grid;
    gap: 0.52rem;
    margin: 0;
    padding: 0;
  }

  .book-hero-steps li {
    counter-increment: book-step;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.52rem;
    align-items: start;
    color: var(--ink-soft);
    font-size: 0.94rem;
  }

  .book-hero-steps li::before {
    content: counter(book-step);
    display: inline-grid;
    place-items: center;
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--book-accent) 42%, var(--stroke));
    color: color-mix(in srgb, var(--ink) 85%, var(--book-accent));
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1;
    margin-top: 0.12rem;
  }

  .book-hero-steps strong {
    display: block;
    color: var(--ink);
    font-size: 0.96rem;
    font-weight: 600;
  }

  .book-hero-steps span {
    display: block;
    font-size: 0.9rem;
  }

  .book-section {
    display: grid;
    gap: 0.88rem;
  }

  .book-section-head {
    display: flex;
    flex-wrap: wrap;
    gap: 0.66rem;
    align-items: center;
  }

  .book-section-head h2 {
    position: relative;
    margin: 0;
    padding-left: 0.74rem;
    letter-spacing: -0.01em;
    font-size: clamp(1.16rem, 2.4vw, 1.34rem);
    color: color-mix(in srgb, var(--ink) 94%, var(--book-accent));
  }

  .book-section-head h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.46em;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--book-accent) 40%, var(--stroke));
  }

  .book-section-note {
    margin: 0;
    font-size: 0.74rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .book-paths {
    gap: 0.98rem;
  }

  .book-path-card {
    min-height: 100%;
    --path-accent: color-mix(in srgb, var(--book-accent) 42%, var(--stroke));
  }

  .book-path-card--teach {
    --path-accent: color-mix(in srgb, var(--cog-blue) 52%, var(--stroke));
  }

  .book-path-card--consult {
    --path-accent: color-mix(in srgb, var(--cog-mint) 50%, var(--stroke));
  }

  .book-path-card--build {
    --path-accent: color-mix(in srgb, var(--book-accent) 50%, var(--stroke));
  }

  .book-path-card :global(.card) {
    position: relative;
    display: grid;
    gap: 0.6rem;
    min-height: 100%;
    padding: clamp(0.92rem, 1.8vw, 1.2rem);
    border-color: color-mix(in srgb, var(--path-accent) 50%, var(--stroke));
    background: color-mix(in srgb, var(--surface) 64%, var(--panel));
    box-shadow: 0 4px 12px color-mix(in srgb, var(--ink) 3.2%, transparent);
    overflow: hidden;
  }

  .book-path-card :global(.card)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0.17rem;
    background: var(--path-accent);
    border-radius: 999px;
    opacity: 0.84;
  }

  .book-path-card :global(h2),
  .book-action :global(h2) {
    margin: 0;
    font-size: clamp(1.28rem, 2.7vw, 1.45rem);
    line-height: 1.1;
  }

  .book-open {
    gap: 0.86rem;
  }

  .book-path-card ul {
    display: grid;
    gap: 0.48rem;
    margin: 0;
    padding-left: 1.2rem;
    color: color-mix(in srgb, var(--ink) 94%, var(--ink-soft));
  }

  .book-path-card li::marker {
    color: var(--path-accent);
  }

  .book-open-scope {
    min-height: 100%;
  }

  .book-open-scope :global(.card) {
    display: grid;
    gap: 0.48rem;
    padding: clamp(0.92rem, 1.8vw, 1.16rem);
    border-color: color-mix(in srgb, var(--book-accent) 24%, var(--stroke));
    background: color-mix(in srgb, var(--surface) 66%, var(--panel));
    box-shadow: 0 4px 11px color-mix(in srgb, var(--ink) 3%, transparent);
  }

  .book-open-scope p {
    max-width: 72ch;
    margin: 0;
  }

  .book-open-links a {
    color: color-mix(in srgb, var(--ink) 88%, var(--book-accent));
    font-weight: 600;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.15em;
  }

  .book-open-links a:hover,
  .book-open-links a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .book-booking {
    gap: 0.92rem;
  }

  .book-booking .text-small {
    margin: 0;
    color: var(--ink-subtle);
  }

  .book-action {
    min-height: 100%;
    --action-accent: color-mix(in srgb, var(--book-accent) 36%, var(--stroke));
  }

  .book-action--coaching {
    --action-accent: color-mix(in srgb, var(--cog-blue) 55%, var(--stroke));
  }

  .book-action--workshop {
    --action-accent: color-mix(in srgb, var(--cog-yellow) 54%, var(--stroke));
  }

  .book-action--class {
    --action-accent: color-mix(in srgb, var(--cog-mint) 56%, var(--stroke));
  }

  .book-action :global(.card) {
    display: grid;
    gap: 0.72rem;
    min-height: 100%;
    padding: clamp(0.9rem, 1.7vw, 1.18rem);
    border-color: color-mix(in srgb, var(--action-accent) 50%, var(--stroke));
    background: color-mix(in srgb, var(--panel) 86%, var(--surface));
    box-shadow: 0 9px 20px color-mix(in srgb, var(--ink) 4%, transparent);
  }

  .book-cta {
    --cta-border: color-mix(in srgb, var(--action-accent) 64%, var(--ink));
    justify-self: start;
    min-width: 13.4rem;
    border-color: var(--cta-border);
    background: color-mix(in srgb, var(--surface) 90%, var(--book-accent) 10%);
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 0.7rem 1.08rem;
    color: color-mix(in srgb, var(--ink) 94%, var(--book-accent));
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .book-cta::after {
    content: '→';
    opacity: 0;
    transform: translateX(-2px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .book-cta:hover,
  .book-cta:focus-visible {
    border-color: color-mix(in srgb, var(--action-accent) 86%, var(--ink));
    background: color-mix(in srgb, var(--surface) 80%, var(--book-accent) 20%);
  }

  .book-cta:hover::after,
  .book-cta:focus-visible::after {
    opacity: 1;
    transform: translateX(0);
  }

  .book-booking .muted {
    margin-top: 0.25rem;
    color: var(--ink-faint);
    font-size: 0.92rem;
  }

  @media (max-width: 720px) {
    .book-shell {
      gap: var(--space-3);
    }

    .book-hero {
      grid-template-columns: minmax(0, 1fr);
      gap: 0.78rem;
      padding: 1rem;
    }

    .book-section-head {
      gap: 0.5rem;
    }

    .book-action :global(.card) {
      min-height: auto;
    }

    .book-cta {
      width: 100%;
      justify-self: stretch;
      min-width: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .book-path-card :global(.card),
    .book-open-scope :global(.card),
    .book-action :global(.card),
    .book-cta,
    .book-cta::after {
      transition: none;
    }
  }
</style>
