---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Code of Conduct" description="Participation norms">
  <header class="page-head">
    <h1>Code of Conduct</h1>
  </header>
  <div class="page-shell prose-measure">
    <p class="text-small">Use respectful, evidence-first behavior in all project channels.</p>
    <p class="text-small">No harassment, manipulative patterns, or privacy violations.</p>
    <p class="text-small">Report concerns directly in project channels and we will act quickly.</p>
  </div>
</BaseLayout>
