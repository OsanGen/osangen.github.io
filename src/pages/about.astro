---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadProfile } from '../lib/content';

const profile = await loadProfile();
const proofBullets = profile.proof_selected.flatMap((entry) => entry.proof).slice(0, 3);
---
<BaseLayout title="About - Oscar Sanchez" description="Short professional snapshot and proof highlights.">
  <header class="page-head">
    <h1>About</h1>
  </header>
  <div class="page-shell">
    <section class="prose-measure">
      <div class="section-spine">
        <span class="section-spine__index" aria-hidden="true">01</span>
        <h2 class="section-spine__label">Snapshot</h2>
      </div>
      <p class="text-small">{profile.headline}</p>
      {profile.summary.slice(0, 2).map((item) => <p class="catalog-summary">{item}</p>)}
    </section>

    <section class="prose-measure">
      <div class="section-spine">
        <span class="section-spine__index" aria-hidden="true">02</span>
        <h2 class="section-spine__label">Proof highlights</h2>
      </div>
      <ul>
        {proofBullets.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="prose-measure">
      <div class="section-spine">
        <span class="section-spine__index" aria-hidden="true">03</span>
        <h2 class="section-spine__label">Links</h2>
      </div>
      <div class="cta-stack">
        <a class="button button--primary" href="/resume">Open resume</a>
        <a class="text-link-inline" href={profile.links.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a class="text-link-inline" href={profile.links.youtube} target="_blank" rel="noopener noreferrer">YouTube</a>
        <a class="text-link-inline" href={profile.links.portfolio} target="_blank" rel="noopener noreferrer">Portfolio</a>
      </div>
    </section>
  </div>
</BaseLayout>
